# Server Configuration
PORT=3000

# MySQL Database Configuration
# Free MySQL hosting options:
#   - Aiven (https://aiven.io) — free plan, 1 MySQL instance
#   - TiDB Cloud Serverless (https://tidbcloud.com) — free tier, MySQL compatible
#   - Railway (https://railway.app) — trial credits with MySQL
#   - Clever Cloud (https://clever-cloud.com) — free MySQL addon
#
# Fill in the credentials from your chosen provider:
DATABASE_URL=mysql://user:password@host:port/database
